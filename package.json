{
  "name": "vscode-md-review",
  "displayName": "Markdown Human Review",
  "description": "Review Markdown plans and specs with anchored notes",
  "version": "0.2.0",
  "license": "MIT",
  "icon": "icon.png",
  "publisher": "xMIkeXeeioi",
  "repository": {
    "type": "git",
    "url": "https://github.com/Michael-vb/vscode-md-review"
  },
  "bugs": {
    "url": "https://github.com/Michael-vb/vscode-md-review/issues"
  },
  "homepage": "https://github.com/Michael-vb/vscode-md-review#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configurationDefaults": {
      "comments.openView": "never"
    },
    "commands": [
      {
        "command": "markdownReview.addComment",
        "title": "Markdown Review: Add comment"
      },
      {
        "command": "markdownReview.copy",
        "title": "Copy Review",
        "icon": "$(copy)"
      },
      {
        "command": "markdownReview.copyAndClean",
        "title": "Copy Review & Clean",
        "icon": "$(trash)"
      },
      {
        "command": "markdownReview.createNote",
        "title": "Add review note",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "markdownReview.editNote",
        "title": "Edit"
      },
      {
        "command": "markdownReview.deleteNote",
        "title": "Delete review"
      },
      {
        "command": "markdownReview.deleteNoteComment",
        "title": "Delete note"
      },
      {
        "command": "markdownReview.saveNote",
        "title": "Save"
      },
      {
        "command": "markdownReview.cancelSaveNote",
        "title": "Cancel"
      }
    ],
    "keybindings": [
      {
        "command": "markdownReview.copy",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "resourceLangId == markdown"
      },
      {
        "command": "markdownReview.copyAndClean",
        "key": "ctrl+alt+x",
        "mac": "cmd+alt+x",
        "when": "resourceLangId == markdown"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "markdownReview.createNote",
          "when": "false"
        },
        {
          "command": "markdownReview.deleteNote",
          "when": "false"
        },
        {
          "command": "markdownReview.deleteNoteComment",
          "when": "false"
        },
        {
          "command": "markdownReview.saveNote",
          "when": "false"
        },
        {
          "command": "markdownReview.cancelSaveNote",
          "when": "false"
        },
        {
          "command": "markdownReview.editNote",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "markdownReview.copy",
          "when": "resourceLangId == markdown",
          "group": "navigation@0"
        },
        {
          "command": "markdownReview.copyAndClean",
          "when": "resourceLangId == markdown",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "markdownReview.addComment",
          "when": "editorLangId == markdown && editorHasSelection",
          "group": "markdownReview@1"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "markdownReview.createNote",
          "group": "inline",
          "when": "commentController == markdownReview && commentThreadIsEmpty"
        },
        {
          "command": "markdownReview.deleteNote",
          "group": "inline@2",
          "when": "commentController == markdownReview && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "markdownReview.editNote",
          "group": "group@1",
          "when": "commentController == markdownReview"
        },
        {
          "command": "markdownReview.deleteNoteComment",
          "group": "group@2",
          "when": "commentController == markdownReview && comment == canDelete"
        }
      ],
      "comments/comment/context": [
        {
          "command": "markdownReview.cancelSaveNote",
          "group": "inline@1",
          "when": "commentController == markdownReview"
        },
        {
          "command": "markdownReview.saveNote",
          "group": "inline@2",
          "when": "commentController == markdownReview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:vsix": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish",
    "publish:openvsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.16.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.7.2"
  }
}
